# =============================================================
# HandySuites — Production Environment Variables Template
# =============================================================
# INSTRUCTIONS:
# 1. Copy this file and fill in real values
# 2. NEVER commit real values to git
# 3. Set these in Vercel Dashboard / Railway Dashboard
# =============================================================

# =====================
# FRONTEND (Vercel)
# =====================
NEXTAUTH_URL=https://app.handycrm.com
NEXTAUTH_SECRET=                          # Generate: openssl rand -base64 32
NEXT_PUBLIC_API_URL=https://api.handycrm.com
NEXT_PUBLIC_BILLING_API_URL=https://billing.handycrm.com
NODE_ENV=production
NEXT_PUBLIC_ENV=production
SOCIAL_LOGIN_SECRET=                      # Must match SocialLogin__SharedSecret on Railway
GOOGLE_CLIENT_ID=                         # From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_SECRET=                     # Same place. Optional — if not set, Google OAuth is disabled
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=       # From Stripe Dashboard → Developers → API keys (pk_live_...)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=           # From Google reCAPTCHA admin console
NEXT_PUBLIC_CHATBOT_URL=https://chatbot.handycrm.com   # Servicio chatbot (bandeja SA + widget); sin esto cae a localhost:1054
NEXT_PUBLIC_WIDGET_URL=https://widget.handycrm.com     # App del widget (loader embed.js en la landing)

# Sprint pre-prod #24: contacto comercial para subscription/expired y billing.
# Si quedan vacios, la seccion "Necesitas ayuda?" se OCULTA por completo (en
# vez de mostrar placeholders fake). Configurar antes de prod release.
NEXT_PUBLIC_SUPPORT_PHONE=                # ej. "+52 81 1234 5678"
NEXT_PUBLIC_SUPPORT_WHATSAPP=             # mismo o distinto numero (formato internacional)
NEXT_PUBLIC_SUPPORT_EMAIL=                # ej. "ventas@handysuites.com"
NEXT_PUBLIC_SUPPORT_HOURS=                # opcional, texto libre. Si vacio usa key i18n monFri

# =====================
# MAIN API (Railway)
# =====================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:${PORT}          # Railway assigns PORT dynamically
ConnectionStrings__DefaultConnection=Host=${PG_HOST};Port=5432;Database=handy_erp;Username=${PG_USER};Password=${PG_PASSWORD};Pooling=true;SSL Mode=Require;Trust Server Certificate=true;
# Sprint pre-prod #26 audit 2026-06-06: nombres alineados con el codigo.
# El template anterior tenia `JWT__SecretKey/Issuer/Audience/ExpirationHours`
# pero el codigo lee `Jwt:Secret`, `Jwt:Issuer`, `Jwt:Audience`,
# `Jwt:ExpirationMinutes` via JwtSettings.cs. En Linux las env vars son
# case-sensitive y el binding nested usa `__` (double underscore). Operador
# siguiendo el template literal arrancaba con `Secret=""` -> crash boot.
Jwt__Secret=                              # Generate: openssl rand -base64 64
Jwt__Issuer=HandySuites
Jwt__Audience=HandySuitesUsers
Jwt__ExpirationMinutes=60                 # 60 min default — match JwtSettings.cs
Multitenancy__DefaultTenantId=00000000-0000-0000-0000-000000000001
Multitenancy__DefaultTenantName=Default
Cloudinary__CloudName=                     # Optional: for file uploads
Cloudinary__ApiKey=
Cloudinary__ApiSecret=
Seq__ServerUrl=                            # Optional: for centralized logging
SENDGRID_API_KEY=                          # From SendGrid dashboard → Settings → API Keys
SENDGRID_FROM_EMAIL=                       # Must be a verified sender in SendGrid (e.g. noreply@handysuites.com)
SENDGRID_FROM_NAME=Handy Suites            # Display name in verification emails
STRIPE_SECRET_KEY=                         # From Stripe Dashboard → Developers → API keys (sk_live_...)
STRIPE_WEBHOOK_SECRET=                     # From Stripe Dashboard → Developers → Webhooks (whsec_...)
SocialLogin__SharedSecret=                 # Shared secret for social login — must match SOCIAL_LOGIN_SECRET in Vercel
RECAPTCHA_SECRET_KEY=                      # From Google reCAPTCHA admin console (server-side secret)
ALLOW_DEV_LOGIN=false                      # MUST be false in production — blocks /api/auth/dev-login

# =====================
# BILLING API (Railway)
# =====================
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://+:${PORT}
ConnectionStrings__BillingConnection=Host=${PG_HOST};Port=5432;Database=handy_billing;Username=${PG_USER};Password=${PG_PASSWORD};Pooling=true;SSL Mode=Require;Trust Server Certificate=true;
ConnectionStrings__MainConnection=Host=${PG_HOST};Port=5432;Database=handy_erp;Username=${PG_USER};Password=${PG_PASSWORD};Pooling=true;SSL Mode=Require;Trust Server Certificate=true;
# JWT__SecretKey=                          # Same as Main API
SAT__CertificadoPath=/app/certificates
SAT__WebServiceUrl=https://consultaqr.facturaelectronica.sat.gob.mx/ConsultaCFDIService.svc

# =====================
# MOBILE API (Railway)
# =====================
# Same variables as Main API

# =====================
# CHATBOT API (Railway — servicio nuevo apps/chatbot, puerto 1054)
# =====================
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://+:${PORT}
ConnectionStrings__ChatDb=Host=${PG_HOST};Port=5432;Database=handy_chat;Username=${PG_USER};Password=${PG_PASSWORD};Pooling=true;SSL Mode=Require;Trust Server Certificate=true;
Jwt__Secret=                              # MISMO secreto/issuer/audience que el Main API (token compartido)
Jwt__Issuer=HandySuites
Jwt__Audience=HandySuitesUsers
OPENAI_API_KEY=                           # OpenAI: chat (gpt-4o-mini) + embeddings + moderacion
INTERNAL_API_KEY=                         # Clave del endpoint interno /kb/ingest
SENDGRID_API_KEY=                         # Notificacion de handoff al asesor (SendGrid propio del bot)
SENDGRID_FROM_EMAIL=                      # Remitente verificado
CHAT__AGENT_EMAILS=                       # Correos de asesores (coma) que reciben el aviso de handoff
CHAT__ALLOWED_ORIGINS=https://app.handycrm.com   # CORS (web + widget); OBLIGATORIO en prod
RECAPTCHA_SECRET_KEY=                     # Anti-bot v3 (server-side)
RECAPTCHA_ENABLED=false                   # Poner true cuando el widget genere tokens reCAPTCHA
CHAT__RETENTION_DAYS=0                    # LFPDPPP: dias para purgar conversaciones cerradas (0 = off)
# FORWARDED_HEADERS: configurar KnownProxies/red del proveedor para rate-limit por IP real

# =====================
# WIDGET (Vercel — proyecto nuevo apps/chat-widget)
# =====================
# NEXT_PUBLIC_CHATBOT_URL=https://chatbot.handycrm.com   # Backend del widget (build-time, CSP connect-src)
# WIDGET_FRAME_ANCESTORS='self' https://app.handycrm.com  # Dominios que pueden embeber el widget (build-time)

# =====================
# POSTGRESQL (Railway)
# =====================
# Railway provides DATABASE_URL automatically
# Parse it to extract host, port, user, password for .NET connection strings
# Format: postgresql://user:password@host:port/database

# =====================
# DOMAINS (Custom)
# =====================
# Frontend:     app.handycrm.com     → Vercel
# Main API:     api.handycrm.com     → Railway (api_main service)
# Billing API:  billing.handycrm.com → Railway (api_billing service)
# Mobile API:   mobile.handycrm.com  → Railway (api_mobile service)
