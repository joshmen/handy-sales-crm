FROM postgis/postgis:16-3.4-alpine

# Install pgvector extension for AI embedding search
RUN apk add --no-cache git build-base postgresql-dev clang15 llvm15 \
    && git clone --branch v0.8.0 https://github.com/pgvector/pgvector.git /tmp/pgvector \
    && cd /tmp/pgvector && make && make install \
    && rm -rf /tmp/pgvector && apk del git build-base clang15 llvm15
