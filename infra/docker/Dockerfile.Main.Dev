# Dockerfile para API Principal - Desarrollo
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS base
WORKDIR /app
EXPOSE 5000

# Instalar herramientas de desarrollo y debugging
RUN apt-get update && apt-get install -y \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copiar archivos de proyecto en orden de dependencias (nueva estructura)
COPY ["libs/HandySuites.Shared/HandySuites.Shared.csproj", "libs/HandySuites.Shared/"]
COPY ["libs/HandySuites.Domain/HandySuites.Domain.csproj", "libs/HandySuites.Domain/"]
COPY ["libs/HandySuites.Application/HandySuites.Application.csproj", "libs/HandySuites.Application/"]
COPY ["libs/HandySuites.Infrastructure/HandySuites.Infrastructure.csproj", "libs/HandySuites.Infrastructure/"]
COPY ["apps/api/src/HandySuites.Api/HandySuites.Api.csproj", "apps/api/src/HandySuites.Api/"]

# Restaurar dependencias
RUN dotnet restore "apps/api/src/HandySuites.Api/HandySuites.Api.csproj"

# Copiar código fuente
COPY libs/ libs/
COPY apps/api/ apps/api/

# Build de la aplicación en modo Debug para desarrollo
WORKDIR "/src/apps/api/src/HandySuites.Api"
RUN dotnet build "HandySuites.Api.csproj" -c Debug -o /app/build

FROM build AS publish
RUN dotnet publish "HandySuites.Api.csproj" -c Debug -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app

# Copiar aplicación publicada
COPY --from=publish /app/publish .

# Crear directorios necesarios con permisos
RUN mkdir -p /app/logs /app/uploads \
    && chmod 755 /app/logs /app/uploads

# Configurar variables de entorno para desarrollo
ENV DOTNET_ENVIRONMENT=Development
ENV ASPNETCORE_HTTP_PORTS=5000
ENV DOTNET_EnableDiagnostics=1
ENV DOTNET_WATCH_RESTART_ON_RUDE_EDIT=1

# Run as non-root user
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
RUN chown -R appuser:appgroup /app
USER appuser

ENTRYPOINT ["dotnet", "HandySuites.Api.dll"]
