# Dockerfile para Chatbot API (bot de la landing) - Desarrollo
# Servicio AUTONOMO: no referencia libs/ del ERP, solo su propio proyecto.
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS base
WORKDIR /app
EXPOSE 1054
RUN apt-get update && apt-get install -y curl procps && rm -rf /var/lib/apt/lists/*

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY ["apps/chatbot/HandySuites.Chatbot.Api/HandySuites.Chatbot.Api.csproj", "apps/chatbot/HandySuites.Chatbot.Api/"]
RUN dotnet restore "apps/chatbot/HandySuites.Chatbot.Api/HandySuites.Chatbot.Api.csproj"
COPY apps/chatbot/ apps/chatbot/
WORKDIR "/src/apps/chatbot/HandySuites.Chatbot.Api"
RUN dotnet build "HandySuites.Chatbot.Api.csproj" -c Debug -o /app/build

FROM build AS publish
RUN dotnet publish "HandySuites.Chatbot.Api.csproj" -c Debug -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .
RUN mkdir -p /app/logs && chmod 755 /app/logs
ENV DOTNET_ENVIRONMENT=Development
ENV ASPNETCORE_HTTP_PORTS=1054
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:1054/health || exit 1
ENTRYPOINT ["dotnet", "HandySuites.Chatbot.Api.dll"]
