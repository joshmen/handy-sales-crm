{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:1052"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mobile-api.handysuites.com"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mobile-api.handysuites.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
